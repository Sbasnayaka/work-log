generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model WorkEntry {
  id        Int      @id @default(autoincrement())
  date      DateTime @db.Date
  workType  String   @map("work_type")
  volume    Decimal  @db.Decimal(10,2)
  unit      String
  performer String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("work_entries")
}

model WorkType {
  id   Int    @id @default(autoincrement())
  name String @unique

  @@map("work_types")
}